# 토스증권 Open API (키 수령 전 — fixture 모드면 비워둬도 됨)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT=            # X-Tossinvest-Account 헤더값(토스증권 계좌)
TOSS_API_BASE=https://openapi.tossinvest.com

# 데이터 소스 모드: fixture | live  (키 수령 전엔 fixture)
DATA_SOURCE=fixture

# Notion (DB ID를 비워두면 해당 DB는 fixture로 동작 — 부분 연동 가능)
NOTION_TOKEN=
NOTION_STOCK_DB_ID=      # 종목 DB (보유 종목 읽기 + 현재가 쓰기 대상)
NOTION_WATCHLIST_DB_ID=  # 별도 '관심종목 DB' (코드/이름 칸 '종목', 정렬 'order')
NOTION_ETF_DB_ID=        # ETF별 구성종목 DB (ETF·구성종목·비중)
NOTION_JOURNAL_DB_ID=    # 매매일지 DB (선택: 체결 임포트)

# 동기화 정책 (CLAUDE.md §11 기본값)
QUOTE_CACHE_TTL_MS=4000
SYNC_INTERVAL_CRON=*/3 9-15 * * 1-5   # 장중 3분 (KST, 운영시간은 코드에서 재확인)
QUOTE_SUCCESS_THRESHOLD=0.9
WATCHLIST_MAX=10        # 관심종목 최대 저장 수

# 체결 임포트 (선택 기능)
ENABLE_TRADE_IMPORT=false

PORT=3000
